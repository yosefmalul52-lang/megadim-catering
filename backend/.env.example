# Copy this file to .env and fill in your values. Never commit .env to version control.
# Google Maps Distance Matrix API key (for delivery fee calculation)
GOOGLE_MAPS_API_KEY=YOUR_API_KEY_HERE

# n8n / external CRM webhooks (optional). POST JSON payload after order/contact is saved. Fail-open if unset or failing.
N8N_ORDER_WEBHOOK_URL=
N8N_CONTACT_WEBHOOK_URL=
N8N_CAMPAIGN_WEBHOOK_URL=
