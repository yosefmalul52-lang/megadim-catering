{
  "name": "megadim-catering",
  "version": "1.0.0",
  "description": "Megadim Catering Website - Premium kosher catering services",
  "scripts": {
    "ng": "ng",
    "dev": "ng serve",
    "start": "ng serve",
    "start:admin": "ng serve --port 4201 --host 0.0.0.0",
    "build": "ng build",
    "build:production": "npm run build:ssr",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "dev:ssr": "ng run megadim-catering:serve-ssr",
    "serve:ssr": "node dist/frontend/server/main.js",
    "build:ssr": "ng build --configuration production && ng run megadim-catering:server:production",
    "vercel-build": "ng build --configuration production && ng run megadim-catering:server:production",
    "prerender": "ng run megadim-catering:prerender"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.2.21",
    "@angular/cdk": "^19.2.19",
    "@angular/common": "^19.2.21",
    "@angular/compiler": "^19.2.21",
    "@angular/core": "^19.2.21",
    "@angular/forms": "^19.2.21",
    "@angular/material": "^19.0.0",
    "@angular/platform-browser": "^19.2.21",
    "@angular/platform-browser-dynamic": "^19.2.21",
    "@angular/platform-server": "^19.2.21",
    "@angular/router": "^19.2.21",
    "@angular/ssr": "^19.2.21",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "chart.js": "^4.4.0",
    "express": "^4.18.2",
    "ng2-charts": "^8.0.0",
    "ngx-toastr": "^19.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.21",
    "@angular/cli": "^19.2.21",
    "@angular/compiler-cli": "^19.2.21",
    "@types/express": "^4.17.17",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^18.18.0",
    "browser-sync": "^3.0.0",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.5.0"
  }
}